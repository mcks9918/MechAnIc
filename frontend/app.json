{
  "expo": {
    "name": "MechAnIc",
    "slug": "mechanic",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "mechanic",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "plugins": [
      "expo-router",
      [
        "expo-image-picker",
        {
          "photosPermission": "Share photos of parts or warning lights with the AI Mechanic",
          "cameraPermission": "Snap a photo of your dashboard light or part"
        }
      ],
      [
        "expo-audio",
        {
          "microphonePermission": "Record symptoms so the AI Mechanic can listen"
        }
      ],
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#05070A"
        }
      ]
    ],
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSCameraUsageDescription": "Snap a photo of a warning light or part",
        "NSPhotoLibraryUsageDescription": "Attach photos to your diagnosis",
        "NSMicrophoneUsageDescription": "Record symptoms for the AI Mechanic"
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#05070A"
      },
      "edgeToEdgeEnabled": true,
      "permissions": ["CAMERA", "RECORD_AUDIO", "READ_EXTERNAL_STORAGE", "READ_MEDIA_IMAGES"]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "experiments": {
      "typedRoutes": true
    }
  }
}
